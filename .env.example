# Copie para /opt/openclaw-router/.env na VPS e ajuste os valores.
# Permissão recomendada: chmod 600 /opt/openclaw-router/.env

# Chaves Gemini
GEMINI_API_KEY_FREE=cole_aqui_sua_key_gratuita
GEMINI_API_KEY_PAID=cole_aqui_sua_key_paga

# Modelos Gemini (defina explicitamente os nomes atuais da sua conta)
# Recomendado: separar flash do free e do paid
GEMINI_MODEL_FLASH_FREE=gemini-2.5-flash
GEMINI_MODEL_FLASH_PAID=gemini-3-flash-preview
GEMINI_MODEL_PRO=gemini-3.1-pro-preview

# Compatibilidade (opcional): se você definir apenas este, ele vale para free+paid
# GEMINI_MODEL_FLASH=gemini-2.5-flash

# Router local (deixe em localhost para não expor na internet)
ROUTER_HOST=127.0.0.1
ROUTER_PORT=8787

# Persistência
ROUTER_DB_PATH=/var/lib/openclaw-router/state.db
FREE_COOLDOWN_SECONDS=3600

# HTTP/API
HTTP_TIMEOUT_SECONDS=60
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Regras (economia vs qualidade)
# true = codigo/debug tenta free+flash antes, false = vai direto paid+flash
CODE_TASKS_USE_FREE_FIRST=false

# Logs
LOG_LEVEL=INFO
